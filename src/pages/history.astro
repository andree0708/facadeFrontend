---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Historia Clínica - Sistema de Gestión Médica">
	<nav class="nav">
		<div class="logo">
			<h2 style="color: #667eea;">🏥 Sistema de Salud</h2>
		</div>
		<div class="nav-links">
			<a href="/dashboard">Dashboard</a>
			<a href="/appointments">Citas</a>
			<a href="/history" class="active">Historia Clínica</a>
			<a href="#" onclick="logout()">Cerrar Sesión</a>
		</div>
	</nav>

	<div class="container">
		<h1 style="margin-bottom: 24px; color: white;">Historia Clínica Completa</h1>
		
		<div class="card">
			<div class="tabs">
				<button class="tab active" onclick="showTab('consultations')">Consultas</button>
				<button class="tab" onclick="showTab('prescriptions')">Prescripciones</button>
				<button class="tab" onclick="showTab('laboratory')">Laboratorio</button>
				<button class="tab" onclick="showTab('new-lab')">Solicitar Exámenes</button>
			</div>

			<div id="consultationsTab">
				<h3 style="margin: 16px 0;">Historial de Consultas</h3>
				<div id="consultationsList">
					<p style="color: #6b7280;">Cargando...</p>
				</div>
			</div>

			<div id="prescriptionsTab" style="display: none;">
				<h3 style="margin: 16px 0;">Prescripciones Médicas</h3>
				<div id="prescriptionsList">
					<p style="color: #6b7280;">Cargando...</p>
				</div>
			</div>

			<div id="laboratoryTab" style="display: none;">
				<h3 style="margin: 16px 0;">Resultados de Laboratorio</h3>
				<div id="laboratoryList">
					<p style="color: #6b7280;">Cargando...</p>
				</div>
			</div>

			<div id="newLabTab" style="display: none;">
				<h3 style="margin: 16px 0;">Solicitar Exámenes de Laboratorio</h3>
				<div class="form-group">
					<label>Seleccionar Exámenes:</label>
					<div class="checkbox-group">
						<label><input type="checkbox" value="hemograma"> Hemograma</label>
						<label><input type="checkbox" value="glicemia"> Glicemia</label>
						<label><input type="checkbox" value="perfil lipídico"> Perfil Lipídico</label>
					</div>
				</div>
				<button class="btn btn-primary" onclick="requestLabTests()">Solicitar Exámenes</button>
				<div id="labRequestMessage" class="alert" style="display: none; margin-top: 16px;"></div>
			</div>
		</div>
	</div>
</Layout>

<script is:inline>
	const API_URL = 'https://clinica-backend-production.up.railway.app/api/clinica';
	const patientId = localStorage.getItem('patientId');

	if (!patientId) {
		window.location.href = '/';
	}

	async function loadHistory() {
		try {
			const response = await fetch(`${API_URL}/historia/${patientId}`);
			const history = await response.json();

			const consultationsDiv = document.getElementById('consultationsList');
			if (history.consultations && history.consultations.length > 0) {
				consultationsDiv.innerHTML = `
					<table class="table">
						<thead>
							<tr>
								<th>Fecha</th>
								<th>Médico</th>
								<th>Especialidad</th>
								<th>Diagnóstico</th>
								<th>Motivo</th>
							</tr>
						</thead>
						<tbody>
							${history.consultations.map(c => `
								<tr>
									<td>${new Date(c.date).toLocaleString('es-CO')}</td>
									<td>${c.doctorName}</td>
									<td>${c.specialty}</td>
									<td>${c.diagnosis}</td>
									<td>${c.reason}</td>
								</tr>
							`).join('')}
						</tbody>
					</table>
				`;
			} else {
				consultationsDiv.innerHTML = '<p style="color: #6b7280; text-align: center;">No hay consultas registradas</p>';
			}

			const prescriptionsDiv = document.getElementById('prescriptionsList');
			if (history.prescriptions && history.prescriptions.length > 0) {
				prescriptionsDiv.innerHTML = history.prescriptions.map(p => `
					<div class="prescription-card">
						<div class="prescription-header">
							<strong>Fecha:</strong> ${new Date(p.date).toLocaleString('es-CO')}
							<span style="margin-left: 16px;"><strong>Médico:</strong> ${p.doctorName}</span>
						</div>
						<table class="table">
							<thead>
								<tr>
									<th>Medicamento</th>
									<th>Dosis</th>
									<th>Duración</th>
								</tr>
							</thead>
							<tbody>
								${p.medications.map(m => `
									<tr>
										<td>${m.name}</td>
										<td>${m.dose}</td>
										<td>${m.duration}</td>
									</tr>
								`).join('')}
							</tbody>
						</table>
					</div>
				`).join('');
			} else {
				prescriptionsDiv.innerHTML = '<p style="color: #6b7280; text-align: center;">No hay prescripciones</p>';
			}

			const laboratoryDiv = document.getElementById('laboratoryList');
			if (history.laboratoryResults && history.laboratoryResults.length > 0) {
				laboratoryDiv.innerHTML = `
					<table class="table">
						<thead>
							<tr>
								<th>Tipo de Examen</th>
								<th>Valor</th>
								<th>Rango de Referencia</th>
								<th>Estado</th>
								<th>Fecha</th>
							</tr>
						</thead>
						<tbody>
							${history.laboratoryResults.map(r => `
								<tr>
									<td>${r.testType}</td>
									<td class="${r.inRange ? 'in-range' : 'out-range'}">
										<strong>${r.value.toFixed(2)}</strong> ${r.unit}
									</td>
									<td>${r.minValue} - ${r.maxValue} ${r.unit}</td>
									<td>
										<span class="status ${r.inRange ? 'status-completed' : 'status-cancelled'}">
											${r.inRange ? 'Normal' : 'Fuera de rango'}
										</span>
									</td>
									<td>${new Date(r.date).toLocaleDateString('es-CO')}</td>
								</tr>
							`).join('')}
						</tbody>
					</table>
				`;
			} else {
				laboratoryDiv.innerHTML = '<p style="color: #6b7280; text-align: center;">No hay resultados de laboratorio</p>';
			}
		} catch (error) {
			console.error('Error loading history:', error);
		}
	}

	async function requestLabTests() {
		const checkboxes = document.querySelectorAll('#newLabTab input[type="checkbox"]:checked');
		const tests = Array.from(checkboxes).map(cb => cb.value);

		if (tests.length === 0) {
			showLabMessage('Por favor seleccione al menos un examen', 'error');
			return;
		}

		try {
			const response = await fetch(`${API_URL}/laboratorio`, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ patientId, tests })
			});

			if (response.ok) {
				showLabMessage('Exámenes solicitados exitosamente', 'success');
				checkboxes.forEach(cb => cb.checked = false);
				loadHistory();
			} else {
				showLabMessage('Error al solicitar los exámenes', 'error');
			}
		} catch (error) {
			showLabMessage('Error de conexión', 'error');
		}
	}

	function showLabMessage(message, type) {
		const msgDiv = document.getElementById('labRequestMessage');
		msgDiv.textContent = message;
		msgDiv.className = `alert alert-${type}`;
		msgDiv.style.display = 'block';
		setTimeout(() => msgDiv.style.display = 'none', 5000);
	}

	function showTab(tabName) {
		const tabs = ['consultations', 'prescriptions', 'laboratory', 'new-lab'];
		tabs.forEach(t => {
			document.getElementById(`${t}Tab`).style.display = t === tabName ? 'block' : 'none';
		});
		document.querySelectorAll('.tab').forEach((t, i) => {
			t.classList.toggle('active', tabs[i] === tabName);
		});
	}

	function logout() {
		localStorage.removeItem('patientId');
		localStorage.removeItem('patientName');
		window.location.href = '/';
	}

	loadHistory();
</script>

<style>
	.checkbox-group {
		display: flex;
		flex-direction: column;
		gap: 8px;
		margin: 12px 0;
	}
	
	.checkbox-group label {
		display: flex;
		align-items: center;
		gap: 8px;
		cursor: pointer;
	}
	
	.checkbox-group input[type="checkbox"] {
		width: auto;
	}
	
	.prescription-card {
		border: 1px solid #e5e7eb;
		border-radius: 8px;
		padding: 16px;
		margin-bottom: 16px;
	}
	
	.prescription-header {
		margin-bottom: 12px;
		padding-bottom: 12px;
		border-bottom: 1px solid #e5e7eb;
	}
</style>