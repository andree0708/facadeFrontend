---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sistema de Gestión Médica">
	<div class="container">
		<div class="auth-container">
			<div class="logo-container">
				<div class="logo-icon">🏥</div>
				<h1>Sistema de Salud</h1>
			</div>
			
			<div class="auth-tabs">
				<button class="tab active" id="loginTab">Iniciar Sesión</button>
				<button class="tab" id="registerTab">Registrarse</button>
			</div>
			
			<div id="loginForm" class="auth-form">
				<div class="form-group">
					<label for="loginDoc">Número de Documento</label>
					<input type="text" id="loginDoc" placeholder="Ingrese su documento" required>
				</div>
				<button class="btn btn-primary" id="loginBtn" onclick="handleLogin()">Ingresar</button>
			</div>
			
			<div id="registerForm" class="auth-form" style="display: none;">
				<div class="form-group">
					<label for="regName">Nombre Completo *</label>
					<input type="text" id="regName" placeholder="Ingrese su nombre" required minlength="2">
				</div>
				<div class="form-group">
					<label for="regDoc">Número de Documento *</label>
					<input type="text" id="regDoc" placeholder="Ingrese su documento" required minlength="5">
				</div>
				<div class="form-group">
					<label for="regEmail">Correo Electrónico *</label>
					<input type="email" id="regEmail" placeholder="ejemplo@correo.com" required pattern="[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$">
				</div>
				<div class="form-group">
					<label for="regPhone">Teléfono *</label>
					<input type="tel" id="regPhone" placeholder="3001234567" required pattern="[0-9]{10}">
				</div>
				<div class="form-group">
					<label for="regBirthDate">Fecha de Nacimiento *</label>
					<input type="date" id="regBirthDate" required>
				</div>
				<div class="form-group">
					<label for="regAllergies">Alergias (opcional)</label>
					<input type="text" id="regAllergies" placeholder="Liste sus alergias si las tiene">
				</div>
				<button class="btn btn-primary" id="registerBtn" onclick="handleRegister()">Registrarse</button>
			</div>
			
			<div id="authMessage" class="alert" style="display: none;"></div>
		</div>
	</div>
</Layout>

<script is:inline>
	const API_URL = "https://facadebackend.onrender.com/api/clinica";

	document.getElementById('loginTab').addEventListener('click', () => showAuthForm('login'));
	document.getElementById('registerTab').addEventListener('click', () => showAuthForm('register'));

	function showAuthForm(form) {
		document.getElementById('loginTab').classList.toggle('active', form === 'login');
		document.getElementById('registerTab').classList.toggle('active', form === 'register');
		document.getElementById('loginForm').style.display = form === 'login' ? 'block' : 'none';
		document.getElementById('registerForm').style.display = form === 'register' ? 'block' : 'none';
		hideMessage();
	}

	function validateEmail(email) {
		const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
		return emailRegex.test(email);
	}

	function validateDocument(document) {
		return document.length >= 5;
	}

	function validatePhone(phone) {
		return phone.length >= 7 && /^\d+$/.test(phone);
	}

	async function handleRegister() {
		const name = document.getElementById('regName').value.trim();
		const docNumber = document.getElementById('regDoc').value.trim();
		const email = document.getElementById('regEmail').value.trim();
		const phone = document.getElementById('regPhone').value.trim();
		const birthDate = document.getElementById('regBirthDate').value;
		const allergies = document.getElementById('regAllergies').value.trim();

		if (!name || !docNumber || !email || !phone || !birthDate) {
			showMessage('Por favor complete todos los campos requeridos', 'error');
			return;
		}

		if (name.length < 2) {
			showMessage('El nombre debe tener al menos 2 caracteres', 'error');
			return;
		}

		if (!validateDocument(docNumber)) {
			showMessage('El documento debe tener al menos 5 caracteres', 'error');
			return;
		}

		if (!validateEmail(email)) {
			showMessage('Por favor ingrese un correo electrónico válido (ej: usuario@correo.com)', 'error');
			return;
		}

		if (!validatePhone(phone)) {
			showMessage('El teléfono debe tener al menos 7 dígitos', 'error');
			return;
		}

		const registerBtn = document.getElementById('registerBtn');
		registerBtn.disabled = true;
		registerBtn.textContent = 'Registrando...';

		try {
			const response = await fetch(`${API_URL}/paciente`, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ name: name, document: docNumber, email: email, phone: phone, birthDate: birthDate, allergies: allergies })
			});

			if (response.ok) {
				const patient = await response.json();
				localStorage.setItem('patientId', patient.id);
				localStorage.setItem('patientName', patient.name);
				window.location.href = '/dashboard';
			} else {
				const errorData = await response.json().catch(() => ({ message: 'Error en el registro' }));
				showMessage(errorData.message || 'El documento puede estar duplicado', 'error');
				registerBtn.disabled = false;
				registerBtn.textContent = 'Registrarse';
			}
		} catch (error) {
			showMessage('Error de conexión. Intente de nuevo.', 'error');
			registerBtn.disabled = false;
			registerBtn.textContent = 'Registrarse';
		}
	}

	async function handleLogin() {
		const docNumber = document.getElementById('loginDoc').value.trim();
		
		if (!docNumber) {
			showMessage('Por favor ingrese su número de documento', 'error');
			return;
		}

		const loginBtn = document.getElementById('loginBtn');
		loginBtn.disabled = true;
		loginBtn.textContent = 'Ingresando...';

		try {
			const response = await fetch(`${API_URL}/paciente`);
			const patients = await response.json();
			
			const patient = patients.find(p => p.document === docNumber);
			
			if (patient) {
				localStorage.setItem('patientId', patient.id);
				localStorage.setItem('patientName', patient.name);
				window.location.href = '/dashboard';
			} else {
				showMessage('Paciente no encontrado. Regístrese primero.', 'error');
				loginBtn.disabled = false;
				loginBtn.textContent = 'Ingresar';
			}
		} catch (error) {
			showMessage('Error de conexión. Intente de nuevo.', 'error');
			loginBtn.disabled = false;
			loginBtn.textContent = 'Ingresar';
		}
	}

	function showMessage(message, type) {
		const msgDiv = document.getElementById('authMessage');
		msgDiv.textContent = message;
		msgDiv.className = `alert alert-${type}`;
		msgDiv.style.display = 'block';
	}

	function hideMessage() {
		document.getElementById('authMessage').style.display = 'none';
	}
</script>

<style>
	.auth-container {
		max-width: 450px;
		margin: 80px auto;
		background: white;
		border-radius: 20px;
		padding: 40px;
		box-shadow: 0 25px 80px rgba(0,0,0,0.15);
	}

	.logo-container {
		text-align: center;
		margin-bottom: 30px;
	}

	.logo-icon {
		font-size: 48px;
		margin-bottom: 10px;
	}

	.logo-container h1 {
		color: #1e3a5f;
		font-size: 24px;
		font-weight: 700;
		margin: 0;
	}

	.auth-tabs {
		display: flex;
		margin-bottom: 30px;
		border-bottom: 3px solid #e8e8e8;
		border-radius: 8px;
		overflow: hidden;
	}

	.auth-tabs .tab {
		flex: 1;
		padding: 14px;
		text-align: center;
		cursor: pointer;
		border: none;
		background: #f5f5f5;
		font-weight: 600;
		color: #666;
		transition: all 0.3s;
	}

	.auth-tabs .tab:first-child {
		border-radius: 8px 0 0 0;
	}

	.auth-tabs .tab:last-child {
		border-radius: 0 8px 0 0;
	}

	.auth-tabs .tab.active {
		background: #1e3a5f;
		color: white;
	}

	.auth-tabs .tab:not(.active):hover {
		background: #e0e0e0;
	}

	.auth-form {
		margin-top: 20px;
	}

	.form-group {
		margin-bottom: 20px;
	}

	.form-group label {
		display: block;
		margin-bottom: 8px;
		font-weight: 600;
		color: #333;
		font-size: 14px;
	}

	.form-group input {
		width: 100%;
		padding: 14px 16px;
		border: 2px solid #ddd;
		border-radius: 10px;
		font-size: 15px;
		transition: all 0.3s;
		background: #fafafa;
	}

	.form-group input:focus {
		outline: none;
		border-color: #1e3a5f;
		background: white;
		box-shadow: 0 0 0 4px rgba(30, 58, 95, 0.1);
	}

	.form-group input::placeholder {
		color: #aaa;
	}

	.form-group input:invalid {
		border-color: #dc2626;
	}

	.btn {
		width: 100%;
		padding: 16px;
		border-radius: 12px;
		border: none;
		cursor: pointer;
		font-weight: 600;
		font-size: 16px;
		transition: all 0.3s;
		margin-top: 10px;
	}

	.btn-primary {
		background: linear-gradient(135deg, #1e3a5f 0%, #2d5a8a 100%);
		color: white;
		box-shadow: 0 4px 15px rgba(30, 58, 95, 0.3);
	}

	.btn-primary:hover:not(:disabled) {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(30, 58, 95, 0.4);
	}

	.btn-primary:disabled {
		background: #ccc;
		cursor: not-allowed;
		box-shadow: none;
	}

	.alert {
		padding: 16px;
		border-radius: 10px;
		margin-top: 20px;
		text-align: center;
		font-weight: 500;
	}

	.alert-error {
		background: #fee2e2;
		color: #dc2626;
		border: 1px solid #fecaca;
	}

	.alert-success {
		background: #d1fae5;
		color: #059669;
		border: 1px solid #a7f3d0;
	}
</style>