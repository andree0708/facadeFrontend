---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Medical Management System">
	<div class="container">
		<div class="auth-container">
			<div class="auth-tabs">
				<button class="tab active" id="loginTab">Login</button>
				<button class="tab" id="registerTab">Register</button>
			</div>
			
			<div id="loginForm" class="auth-form">
				<div class="form-group">
					<label for="loginDocument">Document Number</label>
					<input type="text" id="loginDocument" placeholder="Enter your document number">
				</div>
				<button class="btn btn-primary" onclick="handleLogin()">Sign In</button>
			</div>
			
			<div id="registerForm" class="auth-form" style="display: none;">
				<div class="form-group">
					<label for="regName">Full Name</label>
					<input type="text" id="regName" placeholder="Enter your name">
				</div>
				<div class="form-group">
					<label for="regDocument">Document Number</label>
					<input type="text" id="regDocument" placeholder="Enter your document number">
				</div>
				<div class="form-group">
					<label for="regEmail">Email</label>
					<input type="email" id="regEmail" placeholder="Enter your email">
				</div>
				<div class="form-group">
					<label for="regPhone">Phone</label>
					<input type="tel" id="regPhone" placeholder="Enter your phone">
				</div>
				<div class="form-group">
					<label for="regBirthDate">Birth Date</label>
					<input type="date" id="regBirthDate">
				</div>
				<div class="form-group">
					<label for="regAllergies">Allergies (optional)</label>
					<input type="text" id="regAllergies" placeholder="List your allergies if any">
				</div>
				<button class="btn btn-primary" onclick="handleRegister()">Register</button>
			</div>
			
			<div id="authMessage" class="alert" style="display: none;"></div>
			<div id="loadingSpinner" style="display: none; text-align: center; margin-top: 10px;">
				<span>Loading...</span>
			</div>
		</div>
	</div>
</Layout>

<script is:inline>
	const API_URL = "https://facadebackend.onrender.com/api/clinica";

	document.getElementById('loginTab').addEventListener('click', () => showAuthForm('login'));
	document.getElementById('registerTab').addEventListener('click', () => showAuthForm('register'));

	function showAuthForm(form) {
		document.getElementById('loginTab').classList.toggle('active', form === 'login');
		document.getElementById('registerTab').classList.toggle('active', form === 'register');
		document.getElementById('loginForm').style.display = form === 'login' ? 'block' : 'none';
		document.getElementById('registerForm').style.display = form === 'register' ? 'block' : 'none';
	}

	async function handleRegister() {
		const name = document.getElementById('regName').value;
		const document = document.getElementById('regDocument').value;
		const email = document.getElementById('regEmail').value;
		const phone = document.getElementById('regPhone').value;
		const birthDate = document.getElementById('regBirthDate').value;
		const allergies = document.getElementById('regAllergies').value;

		if (!name || !document || !email || !phone || !birthDate) {
			showMessage('Please fill in all required fields', 'error');
			return;
		}

		showLoading(true);

		try {
			console.log('Registering to:', `${API_URL}/paciente`);
			const response = await fetch(`${API_URL}/paciente`, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ name, document, email, phone, birthDate, allergies })
			});

			console.log('Response status:', response.status);
			
			if (response.ok) {
				const patient = await response.json();
				console.log('Patient registered:', patient);
				localStorage.setItem('patientId', patient.id);
				localStorage.setItem('patientName', patient.name);
				window.location.href = '/dashboard';
			} else {
				const errorText = await response.text();
				console.error('Error response:', errorText);
				showMessage('Registration failed. Document may already be registered.', 'error');
			}
		} catch (error) {
			console.error('Connection error:', error);
			showMessage('Connection error. Please try again.', 'error');
		} finally {
			showLoading(false);
		}
	}

	async function handleLogin() {
		const document = document.getElementById('loginDocument').value;
		
		if (!document) {
			showMessage('Please enter your document number', 'error');
			return;
		}

		showLoading(true);

		try {
			console.log('Logging in, fetching patients from:', `${API_URL}/paciente`);
			const response = await fetch(`${API_URL}/paciente`);
			const patients = await response.json();
			console.log('Patients fetched:', patients);
			
			const patient = patients.find(p => p.document === document);
			
			if (patient) {
				localStorage.setItem('patientId', patient.id);
				localStorage.setItem('patientName', patient.name);
				window.location.href = '/dashboard';
			} else {
				showMessage('Patient not found. Please register first.', 'error');
			}
		} catch (error) {
			console.error('Connection error:', error);
			showMessage('Connection error. Please try again.', 'error');
		} finally {
			showLoading(false);
		}
	}

	function showMessage(message, type) {
		const msgDiv = document.getElementById('authMessage');
		msgDiv.textContent = message;
		msgDiv.className = `alert alert-${type}`;
		msgDiv.style.display = 'block';
		setTimeout(() => msgDiv.style.display = 'none', 5000);
	}

	function showLoading(show) {
		document.getElementById('loadingSpinner').style.display = show ? 'block' : 'none';
	}
</script>

<style>
	.auth-container {
		max-width: 450px;
		margin: 100px auto;
		background: white;
		border-radius: 16px;
		padding: 32px;
		box-shadow: 0 20px 60px rgba(0,0,0,0.2);
	}

	.auth-tabs {
		display: flex;
		margin-bottom: 24px;
		border-bottom: 2px solid #e5e7eb;
	}

	.auth-tabs .tab {
		flex: 1;
		padding: 12px;
		text-align: center;
		cursor: pointer;
		border: none;
		background: none;
		font-weight: 600;
		color: #6b7280;
		border-bottom: 2px solid transparent;
		margin-bottom: -2px;
		transition: all 0.3s;
	}

	.auth-tabs .tab.active {
		color: #667eea;
		border-bottom-color: #667eea;
	}

	.auth-form {
		margin-top: 24px;
	}

	.auth-form .btn {
		width: 100%;
		margin-top: 16px;
	}
</style>