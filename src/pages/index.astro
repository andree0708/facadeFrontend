---
import Layout from '../layouts/Layout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || 'https://facadebackend.onrender.com';
---

<Layout title="Sistema de Gestión Médica">
	<div class="container">
		<div class="auth-container">
			<div class="auth-tabs">
				<button class="tab active" id="loginTab">Iniciar Sesión</button>
				<button class="tab" id="registerTab">Registrarse</button>
			</div>
			
			<div id="loginForm" class="auth-form">
				<div class="form-group">
					<label for="loginDocument">Número de Documento</label>
					<input type="text" id="loginDocument" placeholder="Ingrese su documento">
				</div>
				<button class="btn btn-primary" onclick="handleLogin()">Ingresar</button>
			</div>
			
			<div id="registerForm" class="auth-form" style="display: none;">
				<div class="form-group">
					<label for="regName">Nombre Completo</label>
					<input type="text" id="regName" placeholder="Ingrese su nombre">
				</div>
				<div class="form-group">
					<label for="regDocument">Número de Documento</label>
					<input type="text" id="regDocument" placeholder="Ingrese su documento">
				</div>
				<div class="form-group">
					<label for="regEmail">Correo Electrónico</label>
					<input type="email" id="regEmail" placeholder="Ingrese su correo">
				</div>
				<div class="form-group">
					<label for="regPhone">Teléfono</label>
					<input type="tel" id="regPhone" placeholder="Ingrese su teléfono">
				</div>
				<div class="form-group">
					<label for="regBirthDate">Fecha de Nacimiento</label>
					<input type="date" id="regBirthDate">
				</div>
				<div class="form-group">
					<label for="regAllergies">Alergias (opcional)</label>
					<input type="text" id="regAllergies" placeholder="Liste sus alergias si las tiene">
				</div>
				<button class="btn btn-primary" onclick="handleRegister()">Registrarse</button>
			</div>
			
			<div id="authMessage" class="alert" style="display: none;"></div>
		</div>
	</div>
</Layout>

<script is:inline>
	const API_URL = "https://facadebackend.onrender.com";
	let currentPatientId = null;

	document.getElementById('loginTab').addEventListener('click', () => showAuthForm('login'));
	document.getElementById('registerTab').addEventListener('click', () => showAuthForm('register'));

	function showAuthForm(form) {
		document.getElementById('loginTab').classList.toggle('active', form === 'login');
		document.getElementById('registerTab').classList.toggle('active', form === 'register');
		document.getElementById('loginForm').style.display = form === 'login' ? 'block' : 'none';
		document.getElementById('registerForm').style.display = form === 'register' ? 'block' : 'none';
	}

	async function handleRegister() {
		const name = document.getElementById('regName').value;
		const document = document.getElementById('regDocument').value;
		const email = document.getElementById('regEmail').value;
		const phone = document.getElementById('regPhone').value;
		const birthDate = document.getElementById('regBirthDate').value;
		const allergies = document.getElementById('regAllergies').value;

		if (!name || !document || !email || !phone || !birthDate) {
			showMessage('Por favor complete todos los campos requeridos', 'error');
			return;
		}

		try {
			const response = await fetch(`${API_URL}/api/clinica/paciente`, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ name, document, email, phone, birthDate, allergies })
			});

			if (response.ok) {
				const patient = await response.json();
				currentPatientId = patient.id;
				localStorage.setItem('patientId', patient.id);
				localStorage.setItem('patientName', patient.name);
				window.location.href = '/dashboard';
			} else {
				showMessage('Error al registrar. Documento puede estar duplicado.', 'error');
			}
		} catch (error) {
			showMessage('Error de conexión', 'error');
		}
	}

	async function handleLogin() {
		const document = document.getElementById('loginDocument').value;
		
		if (!document) {
			showMessage('Por favor ingrese su documento', 'error');
			return;
		}

		try {
			const patients = await fetch(`${API_URL}/api/clinica/paciente`).then(r => r.json());
			const patient = patients.find(p => p.document === document);
			
			if (patient) {
				currentPatientId = patient.id;
				localStorage.setItem('patientId', patient.id);
				localStorage.setItem('patientName', patient.name);
				window.location.href = '/dashboard';
			} else {
				showMessage('Paciente no encontrado. Regístrese primero.', 'error');
			}
		} catch (error) {
			showMessage('Error de conexión', 'error');
		}
	}

	function showMessage(message, type) {
		const msgDiv = document.getElementById('authMessage');
		msgDiv.textContent = message;
		msgDiv.className = `alert alert-${type}`;
		msgDiv.style.display = 'block';
		setTimeout(() => msgDiv.style.display = 'none', 5000);
	}
</script>

<style>
	.auth-container {
		max-width: 450px;
		margin: 100px auto;
		background: white;
		border-radius: 16px;
		padding: 32px;
		box-shadow: 0 20px 60px rgba(0,0,0,0.2);
	}

	.auth-tabs {
		display: flex;
		margin-bottom: 24px;
		border-bottom: 2px solid #e5e7eb;
	}

	.auth-tabs .tab {
		flex: 1;
		padding: 12px;
		text-align: center;
		cursor: pointer;
		border: none;
		background: none;
		font-weight: 600;
		color: #6b7280;
		border-bottom: 2px solid transparent;
		margin-bottom: -2px;
		transition: all 0.3s;
	}

	.auth-tabs .tab.active {
		color: #667eea;
		border-bottom-color: #667eea;
	}

	.auth-form {
		margin-top: 24px;
	}

	.auth-form .btn {
		width: 100%;
		margin-top: 16px;
	}
</style>